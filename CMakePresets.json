{
  "version": 3,
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Development Debug",
      "description": "Build in Debug mode using the conan toolchain",
      "binaryDir": "${sourceDir}/build/Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build/Debug/generators/conan_toolchain.cmake"
      }
    }
  ]
}
